datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              Int               @id @default(autoincrement())
  nombre          String
  email           String            @unique
  password        String
  moneda          String            @default("USD")
  salarioMensual  Decimal?
  alertasActivas  Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  ingresos        Ingreso[]
  gastos          Gasto[]
  deudas          Deuda[]
  tarjetas        TarjetaCredito[]
  pagos           Pago[]
}

model Ingreso {
  id          Int      @id @default(autoincrement())
  tipo        String
  monto       Decimal
  descripcion String?
  fecha       DateTime
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model Gasto {
  id           Int      @id @default(autoincrement())
  categoria    String
  subcategoria String?
  monto        Decimal
  descripcion  String?
  fecha        DateTime
  esRecurrente Boolean  @default(false)
  userId       Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
}

model Deuda {
  id            Int            @id @default(autoincrement())
  entidad       String
  tipo          String
  montoOriginal Decimal
  saldoActual   Decimal
  tasaInteres   Decimal?
  cuotaMensual  Decimal?
  fechaInicio   DateTime
  fechaFin      DateTime?
  estado        String         @default("ACTIVA")
  descripcion   String?
  userId        Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  pagos         Pago[]
  amortizaciones Amortizacion[]
}

model TarjetaCredito {
  id           Int      @id @default(autoincrement())
  banco        String
  nombreTarjeta String
  franquicia   String
  cupoTotal    Decimal
  saldoUsado   Decimal  @default(0)
  pagoMinimo   Decimal?
  fechaCorte   Int
  fechaPago    Int
  tasaInteres  Decimal?
  estado       String   @default("ACTIVA")
  descripcion  String?
  userId       Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
  pagos        Pago[]
}

model Pago {
  id          Int            @id @default(autoincrement())
  tipo        String
  monto       Decimal
  fechaPago   DateTime
  descripcion String?
  deudaId     Int?
  tarjetaId   Int?
  userId      Int
  createdAt   DateTime       @default(now())

  user        User           @relation(fields: [userId], references: [id])
  deuda       Deuda?         @relation(fields: [deudaId], references: [id])
  tarjeta     TarjetaCredito? @relation(fields: [tarjetaId], references: [id])
}

model Amortizacion {
  id             Int      @id @default(autoincrement())
  deudaId        Int
  numeroCuota    Int
  fechaPago      DateTime
  cuota          Decimal
  capital        Decimal?
  interes        Decimal?
  seguro         Decimal?
  saldoRestante  Decimal?
  estado         String   @default("PENDIENTE")
  descripcion    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  deuda          Deuda    @relation(fields: [deudaId], references: [id])
}
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}