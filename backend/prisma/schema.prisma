generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  nombre         String
  email          String    @unique
  password       String
  moneda         String    @default("USD")
  salarioMensual Decimal?  @db.Decimal(10,2)
  alertasActivas Boolean   @default(true)
  ingresos       Ingreso[]
  gastos         Gasto[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Ingreso {
  id          Int      @id @default(autoincrement())
  tipo        String
  monto       Decimal  @db.Decimal(10,2)
  descripcion String?
  fecha       DateTime
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Gasto {
  id           Int      @id @default(autoincrement())
  categoria    String
  subcategoria String?
  monto        Decimal  @db.Decimal(10,2)
  descripcion  String?
  fecha        DateTime
  esRecurrente Boolean  @default(false)
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}